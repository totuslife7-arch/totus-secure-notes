{
  "expo": {
    "name": "Totus Secure Notes",
    "slug": "totus-secure-notes",
    "version": "1.2.12",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "totussecurenotes",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.totuslife.TotusSecureNotes",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Totus Secure Notes records trip mileage between patient visits for reimbursement logs.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Totus Secure Notes records trip mileage while the app is in the background during an active visit day.",
        "NSMicrophoneUsageDescription": "Allow Totus Secure Notes to record encrypted voice memos for clinical notes.",
        "UIBackgroundModes": [
          "location"
        ],
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "maps"
        ]
      }
    },
    "android": {
      "package": "com.totuslife.TotusSecureNotes",
      "versionCode": 48,
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow Totus Secure Notes to use Face ID to unlock your encrypted vault."
        }
      ],
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2563eb"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Totus Secure Notes to attach encrypted photos to notes.",
          "cameraPermission": "Allow Totus Secure Notes to capture encrypted photos for notes."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Totus Secure Notes to remove imported photos from your gallery after encrypting them into your vault.",
          "savePhotosPermission": "Allow Totus Secure Notes to manage encrypted note attachments.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Totus Secure Notes to record trip mileage for patient visit reimbursement.",
          "locationWhenInUsePermission": "Allow Totus Secure Notes to record trip mileage between patient visits.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraProguardRules": "-keep class com.google.firebase.** { *; }\n-keep class com.google.android.gms.** { *; }\n-dontwarn com.google.firebase.**\n-keep class com.rnllama.** { *; }"
          }
        }
      ],
      "./plugins/withPlayServicesAdsPin.js",
      [
        "llama.rn",
        {
          "enableEntitlements": true,
          "entitlementsProfile": "production",
          "forceCxx20": true,
          "enableOpenCL": true
        }
      ],
      "expo-iap",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/analytics",
      "@react-native-firebase/crashlytics",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Totus Secure Notes to record encrypted voice memos for notes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "15e52e87-05cb-49f2-8b3b-760d3f81f5a6"
      }
    },
    "owner": "totuslife"
  }
}
