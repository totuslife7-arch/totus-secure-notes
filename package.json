{
  "name": "totus-secure-notes",
  "main": "expo-router/entry",
  "version": "1.2.17",
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@react-native-firebase/analytics": "24.1.1",
    "@react-native-firebase/app": "24.1.1",
    "@react-native-firebase/crashlytics": "24.1.1",
    "expo": "~56.0.12",
    "expo-asset": "~56.0.19",
    "expo-audio": "~56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "~56.0.20",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.7",
    "expo-iap": "^4.3.1",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-local-authentication": "~56.0.4",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-screen-capture": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-task-manager": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "firebase": "^12.15.0",
    "llama.rn": "^0.12.5",
    "nativewind": "^4.2.5",
    "punycode": "^2.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-google-mobile-ads": "16.0.0",
    "react-native-maps": "1.27.2",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "firebase-admin": "^14.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "eas build --platform android --profile preview --non-interactive",
    "build:aab": "eas build --platform android --profile production --non-interactive",
    "build:apk-prod": "eas build --platform android --profile production-apk --non-interactive",
    "build:ios": "eas build --platform ios --profile production --non-interactive",
    "build:ios:preview": "eas build --platform ios --profile preview --non-interactive",
    "build:ios:dev": "eas build --platform ios --profile development --non-interactive",
    "build:android:dev": "eas build --platform android --profile development --non-interactive",
    "build:all": "eas build --platform all --profile production --non-interactive",
    "build:all:preview": "eas build --platform all --profile preview --non-interactive",
    "build:all:dev": "eas build --platform all --profile development --non-interactive",
    "build:store-review": "eas build --platform android --profile store-review --non-interactive",
    "build:store-review-apk": "eas build --platform android --profile store-review-apk --non-interactive",
    "build:store-review-ios": "eas build --platform ios --profile store-review --non-interactive",
    "build:store-review-all": "eas build --platform all --profile store-review --non-interactive",
    "icons:generate": "python scripts/generate_app_icons.py",
    "policies:build": "node firebase/scripts/build-policy-html.mjs",
    "policies:seed": "node firebase/scripts/seed-policies.mjs",
    "vault:export": "npx expo export --platform web",
    "vault:copy": "node scripts/copy-vault-to-firebase.mjs",
    "vault:prepare": "npm run vault:export && npm run vault:copy",
    "firebase:deploy": "npm run policies:build && firebase deploy --config firebase/firebase.json --only firestore:rules,hosting",
    "firebase:deploy:all": "npm run policies:build && npm run policies:seed && firebase deploy --config firebase/firebase.json",
    "eas-build-pre-install": "node scripts/inject-firebase-config.mjs",
    "eas-build-post-install": "node scripts/inject-firebase-config.mjs"
  },
  "private": true,
  "allowScripts": {
    "llama.rn@0.12.5": true
  }
}
